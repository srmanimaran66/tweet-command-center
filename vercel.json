{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/cron/post-tweets",
      "schedule": "0 * * * *"
    }
  ],
  "functions": {
    "api/messages.js": {
      "maxDuration": 60
    }
  }
}
