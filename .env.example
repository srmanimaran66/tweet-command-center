# ── Anthropic ────────────────────────────────────────────────────────────────
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Shared secret between the frontend and the Anthropic proxy.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_TOKEN=

# Frontend reads this to attach the token to every request (must match API_TOKEN).
# Vite exposes only VITE_-prefixed variables to the browser bundle.
VITE_API_TOKEN=

# Restrict CORS to your frontend origin.
# Local dev default: http://localhost:5173
# Production: https://your-app.vercel.app
ALLOWED_ORIGIN=http://localhost:5173


# ── X (Twitter) OAuth 2.0 — required for auto-scheduling ─────────────────────
# 1. Create an app at https://developer.twitter.com/en/portal/dashboard
# 2. Enable OAuth 2.0 with PKCE (Type: Web App)
# 3. Add the callback URL below to "Callback URI / Redirect URL"
# 4. Grant scopes: tweet.write  users.read  offline.access
X_CLIENT_ID=
X_CLIENT_SECRET=
# Local dev:  http://localhost:3001/api/auth/x/callback
# Production: https://your-app.vercel.app/api/auth/x/callback
X_CALLBACK_URL=http://localhost:3001/api/auth/x/callback


# ── Upstash Redis — required for X scheduling ────────────────────────────────
# Set up via Vercel dashboard → Storage → Create Database → Upstash → Redis.
# Vercel populates these automatically after connecting the database to the project.
# Copy the values here for local dev (or run: vercel env pull .env.local)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=


# ── Vercel Cron authentication ────────────────────────────────────────────────
# Vercel sends this as Authorization: Bearer <CRON_SECRET> on cron invocations.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Set in Vercel project settings → Environment Variables.
CRON_SECRET=
