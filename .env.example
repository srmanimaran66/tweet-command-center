# Anthropic API key — get yours at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Shared secret between the frontend and the proxy.
# Generate a strong random value: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_TOKEN=

# Frontend reads this to attach the token to every request (must match API_TOKEN).
# Vite exposes only variables prefixed with VITE_ to the browser bundle.
VITE_API_TOKEN=

# Restrict CORS to your frontend origin (default: http://localhost:5173 for local dev).
# In production set this to your deployed domain, e.g. https://your-app.vercel.app
ALLOWED_ORIGIN=http://localhost:5173
